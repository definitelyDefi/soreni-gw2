    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.3.0",
    "@types/react-native": "^0.73.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^8.19.0",
    "react-test-renderer": "^18.3.1",
    "typescript": "~5.3.3"
