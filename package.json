{
  "name": "soreni",
  "displayName": "Soreni",
  "version": "1.0.0",
  "description": "GW2 companion app — timers, inventory, recipes and more",
  "author": "Denys",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
